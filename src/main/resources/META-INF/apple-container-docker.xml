    <extensions defaultExtensionNs="com.intellij">
        <runLineMarkerContributor language="Dockerfile"
                                   implementationClass="dev.flaticols.applecontainer.run.AppleContainerDockerfileRunLineMarker"/>
    </extensions>
</idea-plugin>
